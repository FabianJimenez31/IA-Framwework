#!/bin/bash
# Git pre-commit hook wrapper. Invokes the main pre-commit check script.
SCRIPT_DIR="$(git rev-parse --show-toplevel)/.claude/hooks"
if [ -f "$SCRIPT_DIR/pre-commit.sh" ]; then
    bash "$SCRIPT_DIR/pre-commit.sh"
else
    echo "⚠️ Warning: .claude/hooks/pre-commit.sh not found."
    exit 0
fi
